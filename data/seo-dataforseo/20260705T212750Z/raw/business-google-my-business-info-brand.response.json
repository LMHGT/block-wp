              "services": [
                {
                  "category": "Mental Health Clinic",
                  "title": "Child Counseling",
                  "snippet": "We specialize in child therapy services help kids navigate emotional challenges, behavioral issues, and developmental transitions. Our experienced staff use play therapy, cognitive behavioral techniques, and family-centered approaches to treat anything from anxiety or ADHD to trauma recovery.",
                  "price": null
                },
                {
                  "category": "Mental Health Clinic",
                  "title": "Family Counseling",
                  "snippet": "Our family therapy services help strengthen relationships, improve communication, and resolve conflicts within the family unit. Our experienced therapists use systemic approaches and evidence-based techniques to address blended family dynamics, parenting challenges, and family behavioral patterns.",
                  "price": null
                },
                {
                  "category": "Mental Health Clinic",
                  "title": "Adult Counseling",
                  "snippet": "Our counseling services for help individuals navigate life transitions, mental health challenges, and personal growth. Our experienced therapists use evidence-based approaches to treat anxiety, depression, trauma, relationship issues, and work-life stress through individualized treatment plans.",
                  "price": null
                },
                {
                  "category": "Counselor",
                  "title": "Trauma Treatment",
                  "snippet": "Our trauma therapy services help you heal from past experiences using specialized approaches like EMDR and trauma focused CBT. Our trauma-informed counselors provide expert treatment for PTSD, complex trauma, childhood trauma, and emotional wounds in a safe, supportive environment.",
                  "price": null
                },
                {
                  "category": "Counselor",
                  "title": "EMDR",
                  "snippet": "EMDR is effective at helping people process and heal from traumatic experiences, anxiety, and distressing memories. Using this proven approach, our trauma specialists guide clients through bilateral stimulation to reduce emotional distress and develop new adaptive responses.",
                  "price": null
                },
                {
                  "category": "Counselor",
                  "title": "Couples Counseling",
                  "snippet": "Our couples therapy services help partners strengthen their connection, improve communication, and resolve relationship conflicts. Our experienced therapists use proven techniques to address intimacy issues, rebuild trust, and develop healthy relationship patterns and emotional bonds.",
                  "price": null
                },
                {
                  "category": "Counselor",
                  "title": "Child Behavioral Intervention",
                  "snippet": "Our child behavioral intervention services help children develop positive behaviors and emotional regulation skills through evidence-based techniques. Licensed staff address ADHD, oppositional behaviors, social challenges, and school-related issues using structured behavioral strategies.",
                  "price": null
                },
                {
                  "category": "Counselor",
                  "title": "Chronic Constipation Treatment",
                  "snippet": "Chronic Constipation in children (medically known as Encopresis) can be treated by mental health professionals. Tyler Horn, LCSW specializes in the treatment of Chronic Constipation in kids. He is one of the only therapists in the Louisville, Ky area who has this as a speciality,",
                  "price": null
                },
                {
                  "category": "Social Worker",
                  "title": "Case Management",
                  "snippet": "Our community-based case management services help Medicaid clients access essential resources and coordinate care needs. Our case managers provide support with healthcare navigation, community services, treatment planning, and connecting to local resources for improved wellbeing.",
                  "price": null
                },
                {
                  "category": "Social Worker",
                  "title": "Therapy in Your Home",
                  "snippet": "Our in-home therapy services bring mental health care directly to you. Our community therapists provide convenient, personalized counseling for clients who prefer treatment in a familiar environment, or face mobility and transportation challenges.",
