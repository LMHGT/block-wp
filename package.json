{
  "name": "lmhg-block-wp",
  "version": "0.1.0",
  "private": true,
  "description": "LMHG WordPress proof track with a block theme, site-core plugin, Playground Blueprint, wp-env, screenshots, and Lighthouse checks.",
  "type": "module",
  "engines": {
    "node": ">=20.18.0",
    "npm": ">=10.2.3"
  },
  "scripts": {
    "check:static": "node tools/check-static.mjs",
    "check:prereqs": "node tools/check-prereqs.mjs",
    "check:prereqs:strict": "node tools/check-prereqs.mjs --strict",
    "inventory:astro": "node tools/export-astro-inventory.mjs",
    "setup:browsers": "playwright install chromium",
    "wp-env:start": "wp-env start",
    "wp-env:stop": "wp-env stop",
    "wp-env:destroy": "wp-env destroy",
    "wp-env:cli": "wp-env run cli wp",
    "wp-env:seed": "node tools/seed-wp-env.mjs",
    "wp-env:import:lmhg": "node tools/seed-lmhg-wp.mjs",
    "verify:lmhg-static": "node tools/verify-lmhg-static.mjs",
    "verify:lmhg-routes": "node tools/verify-lmhg-routes.mjs",
    "verify:lmhg-taxonomies": "node tools/verify-lmhg-taxonomies.mjs",
    "verify:lmhg-redirects": "node tools/verify-lmhg-redirects.mjs",
    "verify:lmhg-links": "node tools/verify-lmhg-links.mjs",
    "verify:lmhg-actions": "node tools/verify-lmhg-actions.mjs",
    "verify:lmhg-head": "node tools/verify-lmhg-head.mjs",
    "verify:lmhg-copy": "node tools/verify-lmhg-copy.mjs",
    "verify:lmhg-markers": "node tools/verify-lmhg-markers.mjs",
    "verify:lmhg": "npm run verify:lmhg-static && npm run verify:lmhg-routes && npm run verify:lmhg-taxonomies && npm run verify:lmhg-redirects && npm run verify:lmhg-links && npm run verify:lmhg-actions && npm run verify:lmhg-head && npm run verify:lmhg-copy && npm run verify:lmhg-markers",
    "playground:start": "node tools/run-playground.mjs",
    "playground:blueprint": "node tools/run-playground.mjs --run-blueprint",
    "test:screenshots": "playwright test --config=tests/playwright.config.mjs",
    "test:lighthouse": "node tools/run-lighthouse.mjs",
    "verify:site": "npm run test:screenshots && npm run test:lighthouse",
    "verify": "npm run check:static && npm run check:prereqs"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@wordpress/env": "11.9.0",
    "@wp-playground/cli": "3.1.42",
    "lighthouse": "12.8.2"
  }
}
