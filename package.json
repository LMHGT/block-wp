{
  "name": "lmhg-wordpress-2026",
  "version": "0.1.0",
  "private": true,
  "description": "LMHG WordPress 2026 source-of-truth repo for the Dell 8093 Playground runtime.",
  "type": "module",
  "engines": {
    "node": ">=20.18.0",
    "npm": ">=10.2.3"
  },
  "scripts": {
    "check:static": "node tools/check-static.mjs",
    "extract:astro-reference": "node tools/extract-astro-reference-data.mjs",
    "runtime:sync": "bash tools/sync-wordpress-2026-runtime.sh",
    "runtime:verify": "node tools/verify-wordpress-2026-source-truth.mjs",
    "verify": "npm run check:static && npm run runtime:verify"
  },
  "devDependencies": {
    "@wp-playground/cli": "3.1.43"
  }
}
